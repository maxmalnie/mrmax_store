# --- Printful API ---
# Pobierz token: https://www.printful.com/dashboard/store -> API
PRINTFUL_API_TOKEN=your_printful_access_token_here
# Opcjonalne — gdy token ma dostęp do wielu store'ów (Account tokens)
PRINTFUL_STORE_ID=
PRINTFUL_API_BASE=https://api.printful.com

# --- App ---
NODE_ENV=development
PORT=4000

# --- Frontend (Vite — prefix VITE_ jest wymagany) ---
VITE_API_BASE=http://localhost:4000
VITE_SHOP_NAME=mrmax store
VITE_CURRENCY=PLN

# --- Webhooks ---
# Printful nie podpisuje webhooków — zabezpieczamy URL przez query token
# (skonfiguruj webhook URL jako: https://twoj-host/api/webhook?token=<ten_sekret>)
PRINTFUL_WEBHOOK_SECRET=generate_random_secret

# --- (opcjonalnie) Stripe do płatności ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
